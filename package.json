{
  "name": "better-in",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "convex": "^1.32.0",
      "better-auth": "1.4.9",
      "@convex-dev/better-auth": "^0.10.11",
      "@tanstack/react-form": "^1.28.0",
      "@better-auth/expo": "1.4.9"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:native": "bun run --filter native dev",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter @better-in/backend dev",
    "dev:setup": "bun run --filter @better-in/backend dev:setup",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@better-in/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-in/config": "workspace:*",
    "@biomejs/biome": "^2.2.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.4"
}
